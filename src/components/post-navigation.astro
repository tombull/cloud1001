---
import Link from '@/components/link.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

const { newerPost, olderPost, parentPost } = Astro.props
const isSubpost = !!parentPost
---

<nav
  class={cn(
    'col-start-2 grid grid-cols-1 gap-4',
    isSubpost ? 'sm:grid-cols-3' : 'sm:grid-cols-2',
  )}
>
  <Link
    href={olderPost ? `/blog/${olderPost.id}#post-title` : '#'}
    class={cn(
      'group flex size-full items-center justify-start border border-outline-variant/20 bg-surface p-4 transition-all duration-300 hover:border-primary/40 hover:bg-surface-container-low',
      !olderPost && 'pointer-events-none cursor-not-allowed opacity-30',
    )}
    aria-disabled={!olderPost}
  >
    <Icon
      name="lucide:arrow-left"
      class="mr-3 size-4 shrink-0 text-on-surface-variant transition-transform group-hover:-translate-x-1"
    />
    <div class="flex flex-col items-start overflow-hidden">
      <span class="text-[10px] tracking-[0.1em] text-on-surface-variant uppercase">
        {isSubpost ? 'Previous Subpost' : 'Previous Post'}
      </span>
      <span class="mt-1 w-full text-left text-sm font-medium text-on-surface text-balance text-ellipsis">
        {
          olderPost?.data.title ||
            (isSubpost ? 'No older subpost' : "You're at the oldest post!")
        }
      </span>
    </div>
  </Link>

  {
    isSubpost && (
      <Link
        href={parentPost ? `/blog/${parentPost.id}#post-title` : '#'}
        class={cn(
          'group flex size-full items-center justify-center border border-outline-variant/20 bg-surface p-4 transition-all duration-300 hover:border-primary/40 hover:bg-surface-container-low',
          !parentPost &&
            'pointer-events-none cursor-not-allowed opacity-30',
        )}
      >
        <Icon
          name="lucide:corner-left-up"
          class="mr-3 size-4 shrink-0 text-on-surface-variant transition-transform group-hover:-translate-y-1"
        />
        <div class="flex flex-col items-center overflow-hidden">
          <span class="text-[10px] tracking-[0.1em] text-on-surface-variant uppercase">
            Parent Post
          </span>
          <span class="mt-1 w-full text-center text-sm font-medium text-on-surface text-balance text-ellipsis">
            {parentPost?.data.title || 'No parent post'}
          </span>
        </div>
      </Link>
    )
  }

  <Link
    href={newerPost ? `/blog/${newerPost.id}#post-title` : '#'}
    class={cn(
      'group flex size-full items-center justify-end border border-outline-variant/20 bg-surface p-4 transition-all duration-300 hover:border-primary/40 hover:bg-surface-container-low',
      !newerPost && 'pointer-events-none cursor-not-allowed opacity-30',
    )}
    aria-disabled={!newerPost}
  >
    <div class="flex flex-col items-end overflow-hidden">
      <span class="text-[10px] tracking-[0.1em] text-on-surface-variant uppercase">
        {isSubpost ? 'Next Subpost' : 'Next Post'}
      </span>
      <span class="mt-1 w-full text-right text-sm font-medium text-on-surface text-balance text-ellipsis">
        {
          newerPost?.data.title ||
            (isSubpost ? 'No newer subpost' : "You're at the newest post!")
        }
      </span>
    </div>
    <Icon
      name="lucide:arrow-right"
      class="ml-3 size-4 shrink-0 text-on-surface-variant transition-transform group-hover:translate-x-1"
    />
  </Link>
</nav>
