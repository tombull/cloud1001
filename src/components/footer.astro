---
import { SITE, SOCIAL_LINKS } from '@/consts'
import { ICON_MAP } from '@/consts'
import Link from './link.astro'
import { Icon } from 'astro-icon/components'
---

<footer class="mt-auto w-full border-t border-primary/15 bg-surface">
  <div
    class="flex w-full flex-col items-center justify-between px-8 py-12 md:flex-row"
  >
    <!-- Brand -->
    <div class="mb-8 md:mb-0">
      <div class="mb-2 text-lg font-black text-on-surface tracking-tighter">
        {SITE.title.toUpperCase()}
      </div>
      <div
        class="text-[10px] tracking-[0.1em] text-on-surface-variant uppercase"
      >
        &copy;{new Date().getFullYear()} TOM BULL. ALL RIGHTS RESERVED.
      </div>
    </div>

    <!-- Nav links -->
    <div class="flex gap-12 text-[10px] tracking-[0.1em] uppercase">
      <Link
        href="/blog"
        class="text-on-surface-variant underline underline-offset-4 transition-colors duration-300 hover:text-primary"
      >
        ARCHIVE
      </Link>
      <Link
        href="/about"
        class="text-on-surface-variant underline underline-offset-4 transition-colors duration-300 hover:text-primary"
      >
        ABOUT
      </Link>
      <Link
        href="/rss.xml"
        class="text-on-surface-variant underline underline-offset-4 transition-colors duration-300 hover:text-primary"
      >
        RSS
      </Link>
    </div>

    <!-- Social icons -->
    <div class="mt-8 flex gap-5 text-on-surface-variant md:mt-0">
      {
        SOCIAL_LINKS.map(({ href, label }) => (
          <Link
            href={href}
            external
            aria-label={label}
            title={label}
            class="transition-colors duration-300 hover:text-primary"
          >
            <Icon
              name={ICON_MAP[label as keyof typeof ICON_MAP] || 'lucide:link'}
              class="size-5"
            />
          </Link>
        ))
      }
    </div>
  </div>
</footer>
