---
import AvatarComponent from '@/components/ui/avatar'
import {
  getCombinedReadingTime,
  getSubpostCount,
  isSubpost,
  parseAuthors,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Link from './link.astro'

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props
const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

<div
  class="group cursor-pointer border border-outline-variant/15 bg-surface transition-colors duration-300 hover:bg-surface-container-low"
>
  <Link
    href={`/archive/${entry.id}`}
    class="flex flex-col gap-4 p-6 sm:flex-row"
  >
    {
      entry.data.image && (
        <div class="w-full sm:max-w-3xs sm:shrink-0">
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            width={1200}
            height={630}
            class="h-full w-full object-cover saturate-50 filter transition-all duration-500 group-hover:saturate-100"
          />
        </div>
      )
    }

    <div class="grow">
      <!-- Metadata row -->
      <div
        class="mb-3 flex flex-wrap items-center gap-x-3 text-[10px] tracking-widest text-tertiary uppercase"
      >
        {
          authors.length > 0 &&
            authors.map((author) => (
              <div class="flex items-center gap-x-1.5">
                <AvatarComponent
                  client:load
                  src={author.avatar}
                  alt={author.name}
                  fallback={author.name[0]}
                  className="size-4"
                />
                <span>{author.name}</span>
              </div>
            ))
        }
        {authors.length > 0 && <span>/</span>}
        <span>{formattedDate}</span>
        <span>/</span>
        <span>{readTime}</span>
        {
          subpostCount > 0 && (
            <>
              <span>/</span>
              <span class="flex items-center gap-1">
                <Icon name="lucide:file-text" class="size-3" />
                {subpostCount} subpost{subpostCount === 1 ? '' : 's'}
              </span>
            </>
          )
        }
      </div>

      <!-- Title -->
      <h3
        class="mb-3 text-xl font-bold leading-tight tracking-tight text-on-surface transition-colors group-hover:text-primary"
      >
        {entry.data.title}
      </h3>

      <!-- Description -->
      <p class="mb-4 text-sm leading-relaxed text-on-surface-variant">
        {entry.data.description}
      </p>

      <!-- Tags -->
      {
        entry.data.tags && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span class="bg-primary/10 px-2 py-0.5 text-[10px] tracking-[0.05em] text-on-surface uppercase">
                <Icon name="lucide:hash" class="mr-0.5 inline size-2.5" />
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </Link>
</div>
