---
import {
  getCombinedReadingTime,
  getSubpostCount,
  isSubpost,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Link from './link.astro'

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props
const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

<div
  class="group border-outline-variant/15 bg-surface hover:bg-surface-container-low cursor-pointer border transition-colors duration-300"
>
  <Link
    href={`/archive/${entry.id}`}
    class="flex flex-col gap-4 p-6 sm:flex-row"
  >
    {
      entry.data.image && (
        <div class="w-full sm:max-w-3xs sm:shrink-0">
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            width={1200}
            height={630}
            class="h-full w-full object-cover saturate-50 filter transition-all duration-500 group-hover:saturate-100"
          />
        </div>
      )
    }

    <div class="grow">
      <!-- Metadata row -->
      <div
        class="text-tertiary mb-3 flex flex-wrap items-center gap-x-3 text-[10px] tracking-widest uppercase"
      >
        <span>{formattedDate}</span>
        <span>/</span>
        <span>{readTime}</span>
        {
          subpostCount > 0 && (
            <>
              <span>/</span>
              <span class="flex items-center gap-1">
                <Icon name="lucide:file-text" class="size-3" />
                {subpostCount} subpost{subpostCount === 1 ? '' : 's'}
              </span>
            </>
          )
        }
      </div>

      <!-- Title -->
      <h3
        class="text-on-surface group-hover:text-primary mb-3 text-xl leading-tight font-bold tracking-tight transition-colors"
      >
        {entry.data.title}
      </h3>

      <!-- Description -->
      <p class="text-on-surface-variant mb-4 text-sm leading-relaxed">
        {entry.data.description}
      </p>

      <!-- Tags -->
      {
        entry.data.tags && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span class="bg-primary/10 text-on-surface px-2 py-0.5 text-[10px] tracking-[0.05em] uppercase">
                <Icon name="lucide:hash" class="mr-0.5 inline size-2.5" />
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </Link>
</div>
