---
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { cva, type VariantProps } from 'class-variance-authority'

// Single-mode: no dark: prefixes. Colors are vivid enough to read on both
// dark (#0e0e0e) and light (#f5f3f0) surfaces.
const calloutConfig = {
  note: {
    style: 'border-blue-400 bg-blue-400/5',
    textColor: 'text-blue-400',
    icon: 'lucide:info',
  },
  tip: {
    style: 'border-green-400 bg-green-400/5',
    textColor: 'text-green-400',
    icon: 'lucide:lightbulb',
  },
  warning: {
    style: 'border-amber-400 bg-amber-400/5',
    textColor: 'text-amber-400',
    icon: 'lucide:alert-triangle',
  },
  danger: {
    style: 'border-red-400 bg-red-400/5',
    textColor: 'text-red-400',
    icon: 'lucide:shield-alert',
  },
  important: {
    style: 'border-purple-400 bg-purple-400/5',
    textColor: 'text-purple-400',
    icon: 'lucide:message-square-warning',
  },
  definition: {
    style: 'border-purple-400 bg-purple-400/5',
    textColor: 'text-purple-400',
    icon: 'lucide:book-open',
  },
  theorem: {
    style: 'border-teal-400 bg-teal-400/5',
    textColor: 'text-teal-400',
    icon: 'lucide:check-circle',
  },
  lemma: {
    style: 'border-sky-400 bg-sky-400/5',
    textColor: 'text-sky-400',
    icon: 'lucide:puzzle',
  },
  proof: {
    style: 'border-outline bg-outline/5',
    textColor: 'text-outline',
    icon: 'lucide:check-square',
  },
  corollary: {
    style: 'border-cyan-400 bg-cyan-400/5',
    textColor: 'text-cyan-400',
    icon: 'lucide:git-branch',
  },
  proposition: {
    style: 'border-slate-400 bg-slate-400/5',
    textColor: 'text-slate-400',
    icon: 'lucide:file-text',
  },
  axiom: {
    style: 'border-violet-400 bg-violet-400/5',
    textColor: 'text-violet-400',
    icon: 'lucide:anchor',
  },
  conjecture: {
    style: 'border-pink-400 bg-pink-400/5',
    textColor: 'text-pink-400',
    icon: 'lucide:help-circle',
  },
  notation: {
    style: 'border-slate-400 bg-slate-400/5',
    textColor: 'text-slate-400',
    icon: 'lucide:pen-tool',
  },
  remark: {
    style: 'border-outline bg-outline/5',
    textColor: 'text-outline',
    icon: 'lucide:message-circle',
  },
  intuition: {
    style: 'border-yellow-400 bg-yellow-400/5',
    textColor: 'text-yellow-400',
    icon: 'lucide:lightbulb',
  },
  recall: {
    style: 'border-blue-300 bg-blue-300/5',
    textColor: 'text-blue-300',
    icon: 'lucide:rotate-ccw',
  },
  explanation: {
    style: 'border-lime-400 bg-lime-400/5',
    textColor: 'text-lime-400',
    icon: 'lucide:help-circle',
  },
  example: {
    style: 'border-emerald-400 bg-emerald-400/5',
    textColor: 'text-emerald-400',
    icon: 'lucide:code',
  },
  exercise: {
    style: 'border-indigo-400 bg-indigo-400/5',
    textColor: 'text-indigo-400',
    icon: 'lucide:dumbbell',
  },
  problem: {
    style: 'border-orange-400 bg-orange-400/5',
    textColor: 'text-orange-400',
    icon: 'lucide:alert-circle',
  },
  answer: {
    style: 'border-teal-400 bg-teal-400/5',
    textColor: 'text-teal-400',
    icon: 'lucide:check',
  },
  solution: {
    style: 'border-emerald-400 bg-emerald-400/5',
    textColor: 'text-emerald-400',
    icon: 'lucide:check-circle-2',
  },
  summary: {
    style: 'border-sky-400 bg-sky-400/5',
    textColor: 'text-sky-400',
    icon: 'lucide:list',
  },
} as const

const capitalize = (str: string) => str.charAt(0).toUpperCase() + str.slice(1)

const calloutVariants = cva('relative px-4 py-3 my-6 border-l-4 text-sm', {
  variants: {
    variant: Object.fromEntries(
      Object.entries(calloutConfig).map(([key, config]) => [key, config.style]),
    ),
  },
  defaultVariants: {
    variant: 'note',
  },
})

interface Props extends VariantProps<typeof calloutVariants> {
  title?: string
  class?: string
  variant?: keyof typeof calloutConfig
  defaultOpen?: boolean
}

const { title, variant = 'note', defaultOpen = true, ...rest } = Astro.props
---

<details
  class={cn(
    calloutVariants({ variant }),
    rest.class,
    '[&[open]>summary_svg:last-child]:rotate-180 [&[open]>summary]:mb-3',
  )}
  {...rest}
  open={defaultOpen}
>
  <summary
    class="flex cursor-pointer items-center font-medium [&::-webkit-details-marker]:hidden"
  >
    <Icon
      name={calloutConfig[variant].icon}
      class={cn('mr-2 size-4 shrink-0', calloutConfig[variant].textColor)}
    />
    <span class={cn('font-medium mr-2', calloutConfig[variant].textColor)}>
      {capitalize(variant)}
      {title && <span class="font-normal opacity-70"> ({title})</span>}
    </span>
    <Icon
      name="lucide:chevron-down"
      class={cn(
        'ml-auto h-4 w-4 shrink-0 transition-transform duration-200',
        calloutConfig[variant].textColor,
      )}
    />
  </summary>
  <div>
    <slot />
  </div>
</details>
