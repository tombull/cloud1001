---
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="px-4 py-12 max-w-3xl md:px-8">
  <PageHead slot="head" title="404 — Not Found" />

  <div class="flex flex-col items-start justify-center gap-6 py-20">
    <div class="text-[10px] tracking-[0.25em] text-primary uppercase">
      ERROR 404
    </div>
    <h1
      class="text-glow text-6xl font-black uppercase leading-none tracking-tighter text-on-surface md:text-8xl"
    >
      NOT<br />FOUND
    </h1>
    <p class="max-w-sm text-sm leading-relaxed text-on-surface-variant">
      The transmission you're looking for doesn't exist, has been moved, or has gone offline.
    </p>
    <a
      href="/"
      class="mt-2 inline-flex items-center gap-2 bg-gradient-to-r from-primary to-primary-container px-6 py-3 text-xs font-bold uppercase tracking-[0.1em] text-on-primary-fixed transition-opacity hover:opacity-90"
    >
      Return to Base &rarr;
    </a>
  </div>
</Layout>
