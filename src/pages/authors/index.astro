---
import AuthorCard from '@/components/author-card.astro'
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getAllAuthors } from '@/lib/data-utils'

const authors = await getAllAuthors()
---

<Layout class="px-4 py-12 max-w-3xl md:px-8">
  <PageHead slot="head" title="Authors" />

  <div class="flex flex-col gap-y-8">
    <div>
      <Breadcrumbs items={[{ label: 'Authors', icon: 'lucide:users' }]} />
      <div class="mt-6 flex items-baseline gap-4">
        <h1 class="text-3xl font-black uppercase tracking-tighter text-on-surface">
          Authors
        </h1>
        <span class="text-[10px] tracking-[0.1em] text-tertiary uppercase">
          [{authors.length} CONTRIBUTOR{authors.length === 1 ? '' : 'S'}]
        </span>
      </div>
    </div>

    {
      authors.length > 0 ? (
        <ul class="flex flex-col gap-4">
          {authors.map((author) => (
            <li>
              <AuthorCard author={author} />
            </li>
          ))}
        </ul>
      ) : (
        <div class="border border-outline-variant/15 p-12 text-center text-on-surface-variant">
          <p class="text-sm tracking-[0.05em] uppercase">No contributors found.</p>
        </div>
      )
    }
  </div>
</Layout>
