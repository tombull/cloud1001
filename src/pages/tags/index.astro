---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getAllTags } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const tags = await getAllTags()
const sortedTags = [...tags.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count)
---

<Layout class="px-4 py-12 max-w-3xl md:px-8">
  <PageHead slot="head" title="Tags" />

  <div class="flex flex-col gap-y-8">
    <div>
      <Breadcrumbs items={[{ href: '/tags', label: 'Tags', icon: 'lucide:tag' }]} />
      <div class="mt-6 flex items-baseline gap-4">
        <h1 class="text-3xl font-black uppercase tracking-tighter text-on-surface">
          Tags
        </h1>
        <span class="text-[10px] tracking-[0.1em] text-tertiary uppercase">
          [{sortedTags.length} LABELS]
        </span>
      </div>
    </div>

    <div class="flex flex-wrap gap-3">
      {
        sortedTags.map(({ tag, count }) => (
          <a
            href={`/tags/${tag}`}
            class="group flex items-center gap-2 border border-outline-variant/15 bg-surface px-4 py-2 text-xs tracking-[0.05em] text-on-surface-variant uppercase transition-all duration-300 hover:border-primary/50 hover:bg-surface-container-low hover:text-on-surface"
          >
            <Icon name="lucide:hash" class="size-3 text-primary" />
            <span>{tag}</span>
            <span class="text-[10px] text-tertiary">
              [{count}]
            </span>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
