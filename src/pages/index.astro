---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const totalPosts = blog.length
---

<Layout fullWidth>
  <PageHead slot="head" title="Home" />

  <!-- Hero Section -->
  <section class="relative w-full">
    <!-- Hero image placeholder: replace the div below with your <Image> when ready -->
    <div
      class="relative h-[60vh] min-h-[400px] w-full overflow-hidden"
      aria-label="Hero image placeholder"
    >
      <!-- Placeholder background -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(135deg, #0e0e0e 0%, #131313 40%, #1a1919 70%, #0e0e0e 100%);"
      >
        <!-- Subtle grid overlay -->
        <div
          class="absolute inset-0 opacity-10"
          style="background-image: linear-gradient(rgba(161,250,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(161,250,255,0.2) 1px, transparent 1px); background-size: 48px 48px;"
        >
        </div>
      </div>
      <!-- Bottom gradient fade -->
      <div class="hero-gradient pointer-events-none absolute inset-0"></div>
    </div>

    <!-- Hero text overlay -->
    <div class="absolute inset-0 flex flex-col justify-end px-8 pb-12 md:px-16">
      <div class="text-primary mb-4 text-[10px] tracking-[0.25em] uppercase">
        ESTABLISHED 2026 &bull; BY TOM BULL
      </div>
      <h1
        class="text-glow text-on-surface mb-4 text-5xl leading-none font-black tracking-tighter uppercase md:text-7xl lg:text-8xl"
      >
        {SITE.title.toUpperCase()}
      </h1>
      <p
        class="text-on-surface-variant max-w-xl text-sm leading-relaxed md:text-base"
      >
        {SITE.description}
      </p>
    </div>

    <!-- Data strip -->
    <div class="data-strip w-full px-8 py-3 md:px-16">
      <div
        class="text-on-surface-variant flex flex-wrap gap-x-8 gap-y-1 text-[10px] tracking-widest uppercase"
      >
        <span>CLOUD 1001</span>
        <span>/</span>
        <span>TECHNOLOGY &middot; AI &middot; CLOUD</span>
        <span>/</span>
        <span
          >{totalPosts} RECENT TRANSMISSION{totalPosts !== 1 ? 'S' : ''}</span
        >
      </div>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="w-full px-8 py-12 md:px-16">
    <!-- Section header -->
    <div class="mb-8 flex items-baseline gap-6">
      <h2
        class="text-on-surface-variant text-xs font-bold tracking-[0.2em] uppercase"
      >
        Latest_Transmissions
      </h2>
      <div class="text-tertiary text-[10px] tracking-[0.1em] uppercase">
        [{totalPosts} ENTRIES]
      </div>
      <div class="ml-auto flex-shrink-0">
        <Link
          href="/archive"
          class="group text-on-surface-variant hover:text-primary flex items-center gap-2 text-[10px] tracking-[0.1em] uppercase transition-colors"
        >
          VIEW ALL
          <span class="transition-transform group-hover:translate-x-1"
            >&rarr;</span
          >
        </Link>
      </div>
    </div>

    <!-- Blog card grid -->
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>

    {
      blog.length === 0 && (
        <div class="border-outline-variant/15 text-on-surface-variant border p-12 text-center">
          <p class="text-sm tracking-[0.05em] uppercase">
            No transmissions yet.
          </p>
        </div>
      )
    }
  </section>
</Layout>
