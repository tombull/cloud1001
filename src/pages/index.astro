---
import HomeHeroCarousel from '@/components/ui/home-hero-carousel'
import HeroShaderOverlay from '@/components/ui/hero-shader-overlay'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import {
  getAllPosts,
  getCombinedReadingTime,
  getSortedTags,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Image } from 'astro:assets'

const BENTO_CARD_COUNT = 5
const allPosts = await getAllPosts()
const heroImages = [
  '/static/home_hero/celestial_dreamers.webp',
  '/static/home_hero/cosmic_duality.webp',
  '/static/home_hero/cosmic_peaks.webp',
  '/static/home_hero/stellar_awakening.webp',
  '/static/home_hero/the_astral_eye.webp',
  '/static/home_hero/the_starlight_citadel.webp',
].map((src) => ({ src }))
const currentDate = new Date()
const systemVersionDate = `${currentDate.getFullYear()}.${String(currentDate.getMonth() + 1).padStart(2, '0')}.${String(currentDate.getDate()).padStart(2, '0')}`
const totalPosts = allPosts.length
const bentoPosts = allPosts.slice(0, BENTO_CARD_COUNT)
const [featuredPost, sidePost, ...smallPosts] = bentoPosts
const readTimes = new Map(
  await Promise.all(
    bentoPosts.map(
      async (post) =>
        [post.id, await getCombinedReadingTime(post.id)] as [string, string],
    ),
  ),
)
const sortedTags = await getSortedTags()
const baseStripTags = sortedTags.map(({ tag }) => tag)
const minimumTickerTags = 101
const repeatCount =
  baseStripTags.length > 0
    ? Math.ceil(minimumTickerTags / baseStripTags.length)
    : 1
const stripTags =
  baseStripTags.length > 0
    ? Array.from({ length: repeatCount }, () => baseStripTags).flat()
    : ['NO TAGS AVAILABLE']
---

<Layout fullWidth>
  <PageHead slot="head" title="Home" />

  <!-- Hero Section -->
  <section class="relative w-full">
    <HomeHeroCarousel client:load className="relative" images={heroImages} />
    <HeroShaderOverlay client:load className="absolute inset-0 z-15" />

    <!-- Hero text overlay -->
    <div
      class="absolute inset-0 flex flex-col justify-end px-8 pb-24 md:px-16 md:pb-32"
    >
      <h1
        class="text-glow text-on-surface pointer-events-none z-20 mb-4 text-7xl leading-none font-black tracking-tighter uppercase select-none md:text-8xl"
      >
        {SITE.title.toUpperCase()}
      </h1>
      <div class="z-20 mb-4 flex items-center gap-4 select-none">
        <div class="bg-primary h-[2px] w-12"></div>
        <span class="font-label text-primary text-sm tracking-[0.2em] uppercase"
          >System Online // Version {systemVersionDate} // Author: {
            SITE.author
          }</span
        >
      </div>
    </div>

    <!-- Data strip -->
    <div
      class="w-full border-y border-[color-mix(in_srgb,var(--primary)_20%,transparent)] bg-[color-mix(in_srgb,var(--primary)_10%,transparent)] py-3 shadow-[inset_0_10px_20px_-12px_color-mix(in_srgb,var(--primary)_10%,transparent),inset_0_-10px_20px_-12px_color-mix(in_srgb,var(--primary)_10%,transparent)]"
    >
      <div class="overflow-hidden whitespace-nowrap" aria-label="Tag ticker">
        <div
          class="text-on-surface-variant flex w-max animate-[data-strip-scroll_300s_linear_infinite] text-[10px] tracking-widest select-none"
        >
          <span class="inline-flex shrink-0 items-center">
            {
              stripTags.map((tag) => (
                <>
                  <a
                    href={`/tags/${encodeURIComponent(tag)}`}
                    class="hover:text-primary uppercase transition-colors duration-200"
                  >
                    {tag}
                  </a>
                  <span class="inline-block px-[2em]" aria-hidden="true">
                    &middot;
                  </span>
                </>
              ))
            }
          </span>
          <span class="inline-flex shrink-0 items-center" aria-hidden="true">
            {
              stripTags.map((tag) => (
                <>
                  <a
                    href={`/tags/${encodeURIComponent(tag)}`}
                    class="hover:text-primary uppercase transition-colors duration-200"
                    tabindex="-1"
                  >
                    {tag}
                  </a>
                  <span class="inline-block px-[2em]" aria-hidden="true">
                    &middot;
                  </span>
                </>
              ))
            }
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="w-full px-8 py-16 md:px-16 md:py-24">
    <!-- Section header -->
    <div
      class="border-outline-variant/15 mb-16 flex items-baseline justify-between border-b pb-4"
    >
      <h2 class="text-on-surface text-2xl font-bold tracking-tight uppercase">
        Latest_Transmissions
      </h2>
      <div class="flex items-center gap-6">
        <span
          class="text-on-surface-variant text-xs tracking-[0.1em] uppercase"
        >
          {String(totalPosts).padStart(2, '0')} ENTRIES FOUND
        </span>
        <Link
          href="/archive"
          class="group text-on-surface-variant hover:text-primary flex items-center gap-2 text-[10px] tracking-[0.1em] uppercase transition-colors"
        >
          VIEW ALL
          <span class="transition-transform group-hover:translate-x-1"
            >&rarr;</span
          >
        </Link>
      </div>
    </div>

    {
      featuredPost ? (
        <div class="border-outline-variant/15 bg-outline-variant/15 grid grid-cols-1 gap-px border md:grid-cols-12">
          <article class="bg-surface hover:bg-surface-container-low transition-colors hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--primary)_35%,transparent)] md:col-span-8">
            <Link
              href={`/archive/${featuredPost.id}`}
              class="group block h-full p-8 md:p-12"
            >
              <div class="flex h-full flex-col gap-8 md:flex-row md:gap-12">
                <div class="flex-1">
                  <div class="text-tertiary mb-6 flex flex-wrap gap-4 text-xs tracking-widest uppercase">
                    <span>{formatDate(featuredPost.data.date)}</span>
                    <span>/</span>
                    <span>
                      {readTimes.get(featuredPost.id) ?? '1 min read'}
                    </span>
                  </div>
                  <h3 class="text-on-surface group-hover:text-primary mb-8 text-4xl leading-[0.95] font-bold tracking-tighter transition-colors md:text-5xl">
                    {featuredPost.data.title}
                  </h3>
                  <p class="text-on-surface-variant mb-10 max-w-xl text-lg leading-relaxed">
                    {featuredPost.data.description}
                  </p>
                  {featuredPost.data.tags &&
                    featuredPost.data.tags.length > 0 && (
                      <div class="flex flex-wrap items-center gap-3">
                        {featuredPost.data.tags.slice(0, 3).map((tag) => (
                          <span class="bg-primary/10 text-on-surface px-3 py-1 text-xs tracking-[0.08em] uppercase">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                </div>
                <div class="border-outline-variant/20 h-64 w-full overflow-hidden border md:h-auto md:w-64">
                  {featuredPost.data.image ? (
                    <Image
                      src={featuredPost.data.image}
                      alt={featuredPost.data.title}
                      width={800}
                      height={800}
                      class="h-full w-full object-cover saturate-50 transition-all duration-500 group-hover:saturate-125"
                    />
                  ) : (
                    <div class="h-full w-full bg-[radial-gradient(circle_at_20%_20%,color-mix(in_srgb,var(--primary)_35%,transparent),transparent_55%),linear-gradient(160deg,color-mix(in_srgb,var(--surface-container-high)_80%,transparent),var(--surface))]" />
                  )}
                </div>
              </div>
            </Link>
          </article>

          {sidePost && (
            <article class="border-outline-variant/15 bg-surface hover:bg-surface-container-low border-l transition-colors hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--primary)_35%,transparent)] md:col-span-4">
              <Link
                href={`/archive/${sidePost.id}`}
                class="group block h-full p-8"
              >
                <div class="flex h-full flex-col justify-between gap-8">
                  <div>
                    <div class="text-on-surface-variant mb-4 flex flex-wrap gap-3 text-[10px] uppercase">
                      <span>{formatDate(sidePost.data.date)}</span>
                      <span>/</span>
                      <span>{readTimes.get(sidePost.id) ?? '1 min read'}</span>
                    </div>
                    <h3 class="text-on-surface group-hover:text-primary mb-5 text-2xl leading-tight font-bold tracking-tight transition-colors">
                      {sidePost.data.title}
                    </h3>
                    <p class="text-on-surface-variant mb-6 text-sm leading-relaxed">
                      {sidePost.data.description}
                    </p>

                    {sidePost.data.tags && sidePost.data.tags.length > 0 && (
                      <div class="flex flex-wrap items-center gap-2">
                        {sidePost.data.tags.slice(0, 3).map((tag) => (
                          <span class="bg-primary/10 text-on-surface px-2 py-0.5 text-[10px] tracking-[0.06em] uppercase">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>

                  <div class="border-outline-variant/10 h-40 w-full overflow-hidden border">
                    {sidePost.data.image ? (
                      <Image
                        src={sidePost.data.image}
                        alt={sidePost.data.title}
                        width={600}
                        height={320}
                        class="h-full w-full object-cover saturate-50 transition-all duration-500 group-hover:saturate-125"
                      />
                    ) : (
                      <div class="h-full w-full bg-[linear-gradient(135deg,color-mix(in_srgb,var(--tertiary)_30%,transparent),var(--surface-container-high))]" />
                    )}
                  </div>
                </div>
              </Link>
            </article>
          )}

          {smallPosts.map((post, index) => (
            <article
              class={`bg-surface hover:bg-surface-container-low transition-colors hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--primary)_35%,transparent)] md:col-span-4 ${
                index === 0
                  ? 'border-outline-variant/15 border-t'
                  : 'border-outline-variant/15 border-t border-l'
              }`}
            >
              <Link
                href={`/archive/${post.id}`}
                class="group block h-full p-8 md:min-h-[280px]"
              >
                <div class="flex h-full flex-col gap-6">
                  <div class="border-outline-variant/10 h-40 w-full shrink-0 overflow-hidden border">
                    {post.data.image ? (
                      <Image
                        src={post.data.image}
                        alt={post.data.title}
                        width={600}
                        height={320}
                        class="h-full w-full object-cover saturate-50 transition-all duration-500 group-hover:saturate-125"
                      />
                    ) : (
                      <div class="h-full w-full bg-[linear-gradient(140deg,color-mix(in_srgb,var(--primary)_25%,transparent),var(--surface-container-high))]" />
                    )}
                  </div>

                  <div class="flex grow flex-col">
                    <div class="text-on-surface-variant mb-2 text-[10px] uppercase">
                      {formatDate(post.data.date)} //{' '}
                      {readTimes.get(post.id) ?? '1 min read'}
                    </div>
                    <h4 class="text-on-surface group-hover:text-primary mb-3 text-xl leading-tight font-bold tracking-tight transition-colors">
                      {post.data.title}
                    </h4>
                    <p class="text-on-surface-variant mb-5 text-sm leading-relaxed">
                      {post.data.description}
                    </p>

                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="mt-auto flex flex-wrap items-center gap-2">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="bg-primary/10 text-on-surface px-2 py-0.5 text-[10px] tracking-[0.06em] uppercase">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </Link>
            </article>
          ))}
        </div>
      ) : (
        <div class="border-outline-variant/15 text-on-surface-variant border p-12 text-center">
          <p class="text-sm tracking-[0.05em] uppercase">
            No transmissions yet.
          </p>
        </div>
      )
    }
  </section>
</Layout>
