---
import BlogCard from '@/components/blog-card.astro'
import HomeHeroCarousel from '@/components/ui/home-hero-carousel'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts, getSortedTags } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const heroImages = [
  '/static/home_hero/celestial_dreamers.webp',
  '/static/home_hero/cosmic_duality.webp',
  '/static/home_hero/cosmic_peaks.webp',
  '/static/home_hero/stellar_awakening.webp',
  '/static/home_hero/the_astral_eye.webp',
  '/static/home_hero/the_starlight_citadel.webp',
].map((src) => ({ src }))
const currentDate = new Date()
const systemVersionDate = `${currentDate.getFullYear()}.${String(currentDate.getMonth() + 1).padStart(2, '0')}.${String(currentDate.getDate()).padStart(2, '0')}`
const totalPosts = blog.length
const sortedTags = await getSortedTags()
const baseStripTags = sortedTags.map(({ tag }) => tag)
const minimumTickerTags = 101
const repeatCount =
  baseStripTags.length > 0
    ? Math.ceil(minimumTickerTags / baseStripTags.length)
    : 1
const stripTags =
  baseStripTags.length > 0
    ? Array.from({ length: repeatCount }, () => baseStripTags).flat()
    : ['NO TAGS AVAILABLE']
---

<Layout fullWidth>
  <PageHead slot="head" title="Home" />

  <!-- Hero Section -->
  <section class="relative w-full">
    <HomeHeroCarousel client:load className="relative" images={heroImages} />
    <div class="pointer-events-none absolute inset-0"></div>

    <!-- Hero text overlay -->
    <div
      class="absolute inset-0 flex flex-col justify-end px-8 pb-24 md:px-16 md:pb-32"
    >
      <h1
        class="text-glow text-on-surface pointer-events-none z-20 mb-4 text-7xl leading-none font-black tracking-tighter uppercase select-none md:text-8xl"
      >
        {SITE.title.toUpperCase()}
      </h1>
      <div class="z-20 mb-4 flex items-center gap-4 select-none">
        <div class="bg-primary h-[2px] w-12"></div>
        <span class="font-label text-primary text-sm tracking-[0.2em] uppercase"
          >System Online // Version {systemVersionDate} // Author: {
            SITE.author
          }</span
        >
      </div>
    </div>

    <!-- Data strip -->
    <div
      class="w-full border-y border-[color-mix(in_srgb,var(--primary)_20%,transparent)] bg-[color-mix(in_srgb,var(--primary)_10%,transparent)] py-3 shadow-[inset_0_10px_20px_-12px_color-mix(in_srgb,var(--primary)_10%,transparent),inset_0_-10px_20px_-12px_color-mix(in_srgb,var(--primary)_10%,transparent)]"
    >
      <div class="overflow-hidden whitespace-nowrap" aria-label="Tag ticker">
        <div
          class="text-on-surface-variant flex w-max animate-[data-strip-scroll_300s_linear_infinite] text-[10px] tracking-widest select-none"
        >
          <span class="inline-flex shrink-0 items-center">
            {
              stripTags.map((tag) => (
                <>
                  <a
                    href={`/tags/${encodeURIComponent(tag)}`}
                    class="hover:text-primary uppercase transition-colors duration-200"
                  >
                    {tag}
                  </a>
                  <span class="inline-block px-[2em]" aria-hidden="true">
                    &middot;
                  </span>
                </>
              ))
            }
          </span>
          <span class="inline-flex shrink-0 items-center" aria-hidden="true">
            {
              stripTags.map((tag) => (
                <>
                  <a
                    href={`/tags/${encodeURIComponent(tag)}`}
                    class="hover:text-primary uppercase transition-colors duration-200"
                    tabindex="-1"
                  >
                    {tag}
                  </a>
                  <span class="inline-block px-[2em]" aria-hidden="true">
                    &middot;
                  </span>
                </>
              ))
            }
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="w-full px-8 py-12 md:px-16">
    <!-- Section header -->
    <div class="mb-8 flex items-baseline gap-6">
      <h2
        class="text-on-surface-variant text-xs font-bold tracking-[0.2em] uppercase"
      >
        Latest_Transmissions
      </h2>
      <div class="text-tertiary text-[10px] tracking-[0.1em] uppercase">
        [{totalPosts} ENTRIES]
      </div>
      <div class="ml-auto shrink-0">
        <Link
          href="/archive"
          class="group text-on-surface-variant hover:text-primary flex items-center gap-2 text-[10px] tracking-[0.1em] uppercase transition-colors"
        >
          VIEW ALL
          <span class="transition-transform group-hover:translate-x-1"
            >&rarr;</span
          >
        </Link>
      </div>
    </div>

    <!-- Blog card grid -->
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>

    {
      blog.length === 0 && (
        <div class="border-outline-variant/15 text-on-surface-variant border p-12 text-center">
          <p class="text-sm tracking-[0.05em] uppercase">
            No transmissions yet.
          </p>
        </div>
      )
    }
  </section>
</Layout>
